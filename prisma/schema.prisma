generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableShape {
  RECTANGLE
  CIRCLE
}

model Table {
  id           String        @id @default(cuid())
  label        String        // misal "T1", "Meja Patio 3"
  seats        Int
  shape        TableShape    @default(RECTANGLE)
  x            Float         // posisi di canvas
  y            Float
  width        Float         @default(80)
  height       Float         @default(80)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]

  @@map("tables")
}

model Reservation {
  id            String            @id @default(cuid())
  tableId       String
  table         Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  startTime     DateTime          @db.Timestamptz(6)
  endTime       DateTime          @db.Timestamptz(6)
  createdAt     DateTime          @default(now())
  items         ReservationItem[]

  @@index([tableId, startTime, endTime])
  @@index([userId])
  @@map("reservations")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  role          UserRole      @default(CUSTOMER)
  createdAt     DateTime      @default(now())
  accounts      Account[]
  sessions      Session[]
  reservations  Reservation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum MenuSection {
  FOOD
  DRINK
  DESSERT
  SNACK
}

model MenuItem {
  id          String            @id @default(cuid())
  name        String
  price       Int               // dalam Rupiah, integer (hindari float untuk uang)
  section     MenuSection
  stock       Int               @default(0)
  isAvailable Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  orderItems  ReservationItem[]

  @@map("menu_items")
}

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  menuItemId    String
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  quantity      Int
  priceAtOrder  Int         // snapshot harga saat dipesan

  @@index([reservationId])
  @@index([menuItemId])
  @@map("reservation_items")
}